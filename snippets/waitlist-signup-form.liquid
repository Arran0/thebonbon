{%- comment -%}
  Renders the waitlist section's own styled name + email signup form.
  Submits directly to Klaviyo's public client API via waitlist-signup-form.js.
  Expects: section
{%- endcomment -%}

<div class="waitlist-{{ section.id }}__form-wrapper">
  <form
    class="waitlist-signup-form"
    data-klaviyo-company-id="{{ section.settings.klaviyo_public_api_key }}"
    data-klaviyo-list-id="{{ section.settings.klaviyo_list_id }}"
  >
    <div class="waitlist-{{ section.id }}__fields" data-waitlist-fields>
      <div class="waitlist-{{ section.id }}__field">
        <input
          type="text"
          id="WaitlistName-{{ section.id }}"
          class="field__input"
          data-waitlist-name
          autocomplete="given-name"
          aria-label="Your name"
          placeholder="your name here"
        >
      </div>

      <div class="waitlist-{{ section.id }}__field">
        <input
          type="email"
          id="WaitlistEmail-{{ section.id }}"
          class="field__input"
          data-waitlist-email
          autocomplete="email"
          autocorrect="off"
          autocapitalize="off"
          spellcheck="false"
          required
          aria-required="true"
          aria-label="Your email"
          placeholder="your mail id here"
        >
      </div>

      <button type="submit" class="waitlist-{{ section.id }}__form-button">
        Join Waitlist
      </button>

      <small class="waitlist-{{ section.id }}__form-error" data-waitlist-error hidden></small>
    </div>

    <p class="waitlist-{{ section.id }}__form-success" data-waitlist-success hidden>
      {{- 'icon-success.svg' | inline_asset_content -}}
      You're on the list!
    </p>
  </form>
</div>

{%- if section.settings.klaviyo_form_class != blank -%}
  <div class="{{ section.settings.klaviyo_form_class }} waitlist-{{ section.id }}__klaviyo-hidden" aria-hidden="true"></div>
{%- endif -%}
