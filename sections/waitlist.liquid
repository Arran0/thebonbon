{%- liquid
  assign heading_font = section.settings.accent_font
  assign subheading_font = section.settings.subheading_font
  assign button_font = section.settings.button_font
  assign input_font = section.settings.input_font
  assign card_alpha = section.settings.card_opacity | divided_by: 100.0

  # Fluid, proportional sizing: these values scale continuously with the
  # rendered width of the window graphic (via CSS container query units)
  # instead of staying fixed while the window shrinks on a phone. 6.2 is
  # 1% of the window's 620px default base width (window_max_width), i.e.
  # what 1cqw equals at that width -- so at that width each value resolves
  # back to the exact px the merchant set, and scales down below that.
  # (If a merchant raises window_max_width, these values simply hit their
  # ceiling a bit earlier relative to the window's new, larger cap --
  # harmless, since clamp() always caps the final value at that ceiling.)
  assign heading_size_floor = section.settings.heading_size | times: 0.6 | at_least: 12 | at_most: section.settings.heading_size
  assign heading_size_cqw = section.settings.heading_size | divided_by: 6.2

  assign button_size_floor = section.settings.button_size | times: 0.65 | at_least: 12 | at_most: section.settings.button_size
  assign button_size_cqw = section.settings.button_size | divided_by: 6.2

  # Input floor stays at 16px (never lower) so mobile Safari doesn't
  # zoom in on focus, unless the merchant's own desktop size is smaller.
  assign input_size_floor = 16 | at_most: section.settings.input_size
  assign input_size_cqw = section.settings.input_size | divided_by: 6.2

  # Card padding's mobile floor is merchant-editable (card_padding_mobile)
  # instead of an auto ratio, so it can be dialled in directly.
  assign card_padding_floor = section.settings.card_padding_mobile | at_most: section.settings.card_padding
  assign card_padding_cqw = section.settings.card_padding | divided_by: 6.2

  assign card_min_height_floor = section.settings.card_min_height | times: 0.5 | at_most: section.settings.card_min_height
  assign card_min_height_cqw = section.settings.card_min_height | divided_by: 6.2

  assign card_offset_x_cqw = section.settings.card_offset_x | divided_by: 6.2
  assign card_offset_y_cqw = section.settings.card_offset_y | divided_by: 6.2
  assign card_offset_x_mobile_cqw = section.settings.card_offset_x_mobile | divided_by: 6.2
  assign card_offset_y_mobile_cqw = section.settings.card_offset_y_mobile | divided_by: 6.2

  # Window zoom mirrors the card's before/after style: both are plain
  # percentages of the window's base width, and either can go past 100%.
  # To keep this safe (so the window can never grow into the logo above
  # or the subheading below, even past 100%), the space actually reserved
  # in the page layout is the "after" size, not the raw base width -- the
  # window only ever animates within space already set aside for it.
  assign window_static_max_width = section.settings.window_max_width
  assign window_static_max_width_mobile = section.settings.window_max_width_mobile
  assign window_rest_scale = 1.0
  if section.settings.zoom_enable
    assign window_static_max_width = section.settings.window_max_width | times: section.settings.zoom_after_scale | divided_by: 100.0
    assign window_static_max_width_mobile = section.settings.window_max_width_mobile | times: section.settings.zoom_after_scale | divided_by: 100.0
    assign window_rest_scale = section.settings.zoom_before_scale | times: 1.0 | divided_by: section.settings.zoom_after_scale
  endif

  # The content column's own max-width used to be a flat 68rem (1088px),
  # which silently capped the window below that regardless of how high
  # window_max_width (or its zoom "after" %) was set. It now grows to
  # match whichever configured window size is largest, plus room for its
  # own side padding, so it's never the bottleneck.
  assign content_max_width = window_static_max_width | at_least: window_static_max_width_mobile | plus: 48 | at_least: 1088

  # Name/email box height + rounding and the Join button's padding are
  # fully editable per view: the "mobile" setting is the floor, the
  # "desktop" setting is the ceiling, and it scales fluidly between them.
  assign field_height_floor = section.settings.field_height_mobile | at_most: section.settings.field_height
  assign field_height_cqw = section.settings.field_height | divided_by: 6.2

  assign field_radius_floor = section.settings.field_radius_mobile | at_most: section.settings.field_radius
  assign field_radius_cqw = section.settings.field_radius | divided_by: 6.2

  assign button_padding_v_floor = section.settings.button_padding_v_mobile | at_most: section.settings.button_padding_v
  assign button_padding_v_cqw = section.settings.button_padding_v | divided_by: 6.2

  assign button_padding_h_floor = section.settings.button_padding_h_mobile | at_most: section.settings.button_padding_h
  assign button_padding_h_cqw = section.settings.button_padding_h | divided_by: 6.2
-%}
{%- style -%}
  {% if heading_font %}{{ heading_font | font_face: font_display: 'swap' }}{% endif %}
  {% if subheading_font %}{{ subheading_font | font_face: font_display: 'swap' }}{% endif %}
  {% if button_font %}{{ button_font | font_face: font_display: 'swap' }}{% endif %}
  {% if input_font %}{{ input_font | font_face: font_display: 'swap' }}{% endif %}

  .waitlist-{{ section.id }} {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: visible;
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    min-height: {{ section.settings.min_height }}px;
  }

  @media screen and (min-width: 750px) {
    .waitlist-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .waitlist-{{ section.id }}__background {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .waitlist-{{ section.id }}__background img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    {% if section.settings.background_zoom_enable %}
      transform: scale({{ section.settings.background_zoom_start_scale | divided_by: 100.0 }});
      transform-origin: center center;
      transition: transform {{ section.settings.background_zoom_duration | divided_by: 1000.0 }}s cubic-bezier(0.16, 1, 0.3, 1);
      will-change: transform;
    {% endif %}
  }

  {% if section.settings.background_zoom_enable %}
    .waitlist-{{ section.id }}.waitlist-in-view .waitlist-{{ section.id }}__background img {
      transform: scale(1);
    }
  {% endif %}

  .waitlist-{{ section.id }}__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  }

  .waitlist-{{ section.id }}__content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: {{ content_max_width }}px;
    margin: 0 auto;
    text-align: {{ section.settings.content_alignment }};
    display: flex;
    flex-direction: column;
    align-items: {% if section.settings.content_alignment == 'left' %}flex-start{% elsif section.settings.content_alignment == 'right' %}flex-end{% else %}center{% endif %};
    padding: 0 1.5rem;
  }

  .waitlist-{{ section.id }}__logo-wrapper {
    position: relative;
    z-index: 3;
    margin-bottom: 0.4rem;
    transform: translate({{ section.settings.logo_offset_x_mobile }}px, {{ section.settings.logo_offset_y_mobile }}px){% if section.settings.logo_zoom_enable %} scale({{ section.settings.logo_zoom_before_scale | divided_by: 100.0 }}){% endif %};
    {% if section.settings.logo_zoom_enable %}
      transition: transform {{ section.settings.zoom_duration | divided_by: 1000.0 }}s cubic-bezier(0.16, 1, 0.3, 1);
      will-change: transform;
    {% endif %}
  }

  {% if section.settings.logo_zoom_enable %}
    .waitlist-{{ section.id }}__logo-wrapper.waitlist-in-view {
      transform: translate({{ section.settings.logo_offset_x_mobile }}px, {{ section.settings.logo_offset_y_mobile }}px) scale({{ section.settings.logo_zoom_after_scale | divided_by: 100.0 }});
    }
  {% endif %}

  @media screen and (min-width: 750px) {
    .waitlist-{{ section.id }}__logo-wrapper {
      transform: translate({{ section.settings.logo_offset_x }}px, {{ section.settings.logo_offset_y }}px){% if section.settings.logo_zoom_enable %} scale({{ section.settings.logo_zoom_before_scale | divided_by: 100.0 }}){% endif %};
    }

    {% if section.settings.logo_zoom_enable %}
      .waitlist-{{ section.id }}__logo-wrapper.waitlist-in-view {
        transform: translate({{ section.settings.logo_offset_x }}px, {{ section.settings.logo_offset_y }}px) scale({{ section.settings.logo_zoom_after_scale | divided_by: 100.0 }});
      }
    {% endif %}
  }

  .waitlist-{{ section.id }}__logo {
    width: {{ section.settings.logo_width }}px;
    max-width: 90%;
    height: auto;
  }

  /* Every piece of text on the page has its own font / size / color,
     editable from that element's own section in the theme editor
     (Heading, Card, Logo, Subheading, Signup form). */
  .waitlist-{{ section.id }}__heading {
    margin: 0;
    line-height: 1.2;
    letter-spacing: 0.06em;
    font-size: clamp({{ heading_size_floor | divided_by: 10.0 }}rem, {{ heading_size_cqw }}cqw, {{ section.settings.heading_size | divided_by: 10.0 }}rem);
    color: {{ section.settings.heading_color }};
    {% if heading_font %}
      font-family: {{ heading_font.family }}, {{ heading_font.fallback_families }};
      font-weight: {{ heading_font.weight }};
      font-style: {{ heading_font.style }};
    {% else %}
      font-weight: 700;
    {% endif %}
  }

  .waitlist-{{ section.id }}__form-button {
    letter-spacing: 0.06em;
    font-size: clamp({{ button_size_floor | divided_by: 10.0 }}rem, {{ button_size_cqw }}cqw, {{ section.settings.button_size | divided_by: 10.0 }}rem);
    color: {{ section.settings.button_color }};
    {% if button_font %}
      font-family: {{ button_font.family }}, {{ button_font.fallback_families }};
      font-weight: {{ button_font.weight }};
      font-style: {{ button_font.style }};
    {% else %}
      font-weight: 700;
    {% endif %}
  }

  .waitlist-{{ section.id }}__subheading {
    position: relative;
    z-index: 3;
    margin: 1.25rem 0 0;
    padding: 0.6rem 1.4rem;
    border-radius: 999px;
    background: #ffffff;
    white-space: nowrap;
    max-width: 100%;
    overflow-x: auto;
    letter-spacing: 0.06em;
    font-size: {{ section.settings.subheading_size | divided_by: 10.0 }}rem;
    color: {{ section.settings.subheading_color }};
    transform: translate({{ section.settings.subheading_offset_x_mobile }}px, {{ section.settings.subheading_offset_y_mobile }}px){% if section.settings.subheading_zoom_enable %} scale({{ section.settings.subheading_zoom_before_scale | divided_by: 100.0 }}){% endif %};
    {% if subheading_font %}
      font-family: {{ subheading_font.family }}, {{ subheading_font.fallback_families }};
      font-weight: {{ subheading_font.weight }};
      font-style: {{ subheading_font.style }};
    {% else %}
      font-weight: 700;
    {% endif %}
    {% if section.settings.subheading_zoom_enable %}
      transition: transform {{ section.settings.zoom_duration | divided_by: 1000.0 }}s cubic-bezier(0.16, 1, 0.3, 1);
      will-change: transform;
    {% endif %}
  }

  {% if section.settings.subheading_zoom_enable %}
    .waitlist-{{ section.id }}__subheading.waitlist-in-view {
      transform: translate({{ section.settings.subheading_offset_x_mobile }}px, {{ section.settings.subheading_offset_y_mobile }}px) scale({{ section.settings.subheading_zoom_after_scale | divided_by: 100.0 }});
    }
  {% endif %}

  @media screen and (min-width: 750px) {
    .waitlist-{{ section.id }}__subheading {
      transform: translate({{ section.settings.subheading_offset_x }}px, {{ section.settings.subheading_offset_y }}px){% if section.settings.subheading_zoom_enable %} scale({{ section.settings.subheading_zoom_before_scale | divided_by: 100.0 }}){% endif %};
    }

    {% if section.settings.subheading_zoom_enable %}
      .waitlist-{{ section.id }}__subheading.waitlist-in-view {
        transform: translate({{ section.settings.subheading_offset_x }}px, {{ section.settings.subheading_offset_y }}px) scale({{ section.settings.subheading_zoom_after_scale | divided_by: 100.0 }});
      }
    {% endif %}
  }

  /* Normalize whatever tag the subheading richtext uses (p, h5, ...)
     so it always renders in the shared accent style, not a heading. */
  .waitlist-{{ section.id }}__subheading > * {
    margin: 0;
    font-size: inherit;
    font-weight: inherit;
    font-family: inherit;
    letter-spacing: inherit;
    color: inherit;
    line-height: 1.3;
  }

  .waitlist-{{ section.id }}__window {
    position: relative;
    width: {{ window_static_max_width_mobile }}px;
    container-type: inline-size;
    transform: translate({{ section.settings.window_offset_x_mobile }}px, {{ section.settings.window_offset_y_mobile }}px){% if section.settings.zoom_enable %} scale({{ window_rest_scale }}){% endif %};
    {% if section.settings.zoom_enable %}
      transform-origin: center center;
      transition: transform {{ section.settings.zoom_duration | divided_by: 1000.0 }}s cubic-bezier(0.16, 1, 0.3, 1);
      will-change: transform;
    {% endif %}
  }

  {% if section.settings.zoom_enable %}
    .waitlist-{{ section.id }}__window.waitlist-in-view {
      transform: translate({{ section.settings.window_offset_x_mobile }}px, {{ section.settings.window_offset_y_mobile }}px) scale(1);
    }
  {% endif %}

  @media screen and (min-width: 750px) {
    .waitlist-{{ section.id }}__window {
      width: {{ window_static_max_width }}px;
      transform: translate({{ section.settings.window_offset_x }}px, {{ section.settings.window_offset_y }}px){% if section.settings.zoom_enable %} scale({{ window_rest_scale }}){% endif %};
    }

    {% if section.settings.zoom_enable %}
      .waitlist-{{ section.id }}__window.waitlist-in-view {
        transform: translate({{ section.settings.window_offset_x }}px, {{ section.settings.window_offset_y }}px) scale(1);
      }
    {% endif %}
  }

  @media (prefers-reduced-motion: reduce) {
    .waitlist-{{ section.id }}__window,
    .waitlist-{{ section.id }}__logo-wrapper,
    .waitlist-{{ section.id }}__subheading,
    .waitlist-{{ section.id }}__card,
    .waitlist-{{ section.id }}__background img {
      transition: none;
    }
  }

  .waitlist-{{ section.id }}__window-image-frame {
    position: relative;
    width: 100%;
  }

  .waitlist-{{ section.id }}__window-image-frame img {
    display: block;
    width: 100%;
    height: auto;
  }

  .waitlist-{{ section.id }}__window-image-slot {
    position: absolute;
    top: {{ section.settings.window_image_slot_top }}%;
    left: {{ section.settings.window_image_slot_left }}%;
    width: {{ section.settings.window_image_slot_width }}%;
    height: {{ section.settings.window_image_slot_height }}%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: clamp(0.65rem, 2.097cqw, 1.3rem);
    overflow: visible;
    padding: 0.5rem;
  }

  .waitlist-{{ section.id }}__window-arch {
    position: relative;
    width: 100%;
    aspect-ratio: 2 / 1;
    overflow: hidden;
    border: 7px solid {{ section.settings.window_frame_color }};
    border-bottom: none;
    border-radius: 50% 50% 0 0 / 100% 100% 0 0;
    background: {{ section.settings.window_glass_color | color_modify: 'alpha', section.settings.window_glass_opacity | divided_by: 100.0 }};
    backdrop-filter: blur(7px) saturate(115%);
    -webkit-backdrop-filter: blur(7px) saturate(115%);
    box-shadow: inset 0 0 22px rgba(255, 255, 255, 0.45);
  }

  .waitlist-{{ section.id }}__window-mullion {
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 2px;
    height: 100%;
    background: {{ section.settings.window_frame_color }};
    transform-origin: bottom center;
  }

  .waitlist-{{ section.id }}__window-mullion--left {
    transform: translateX(-50%) rotate(-30deg);
  }

  .waitlist-{{ section.id }}__window-mullion--center {
    transform: translateX(-50%);
  }

  .waitlist-{{ section.id }}__window-mullion--right {
    transform: translateX(-50%) rotate(30deg);
  }

  .waitlist-{{ section.id }}__window-body {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: clamp(0.6rem, 2.016cqw, 1.25rem);
    border: 7px solid {{ section.settings.window_frame_color }};
    border-top: none;
    border-radius: 0 0 16px 16px;
    background: {{ section.settings.window_glass_color | color_modify: 'alpha', section.settings.window_glass_opacity | divided_by: 100.0 }};
    backdrop-filter: blur(7px) saturate(115%);
    -webkit-backdrop-filter: blur(7px) saturate(115%);
    box-shadow:
      inset 0 0 22px rgba(255, 255, 255, 0.35),
      0 20px 32px -14px rgba(80, 50, 40, 0.35);
    padding: clamp(1rem, 3.226cqw, 2rem) clamp(1rem, 3.226cqw, 2rem) clamp(0.9rem, 2.823cqw, 1.75rem);
    min-height: clamp(8rem, 25.806cqw, 16rem);
  }

  .waitlist-{{ section.id }}__window-transom {
    position: absolute;
    top: 0;
    left: -7px;
    right: -7px;
    height: 6px;
    background: {{ section.settings.window_frame_color }};
  }

  .waitlist-{{ section.id }}__window-sill {
    width: 112%;
    height: 8px;
    margin: 0 auto;
    transform: translateX(-5.4%);
    background: {{ section.settings.window_frame_color }};
    border-radius: 2px;
    box-shadow: 0 5px 10px rgba(80, 50, 40, 0.25);
  }

  /* White translucent card that groups the heading + form together.
     Its corner position and size are driven by the theme editor. */
  .waitlist-{{ section.id }}__card {
    position: relative;
    z-index: 1;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: clamp(0.65rem, 2.097cqw, 1.3rem);
    width: 100%;
    max-width: {{ section.settings.card_width }}%;
    min-height: clamp({{ card_min_height_floor }}px, {{ card_min_height_cqw }}cqw, {{ section.settings.card_min_height }}px);
    padding: clamp({{ card_padding_floor }}px, {{ card_padding_cqw }}cqw, {{ section.settings.card_padding }}px);
    border-radius: {{ section.settings.card_radius }}px;
    transform: translate({{ card_offset_x_mobile_cqw }}cqw, {{ card_offset_y_mobile_cqw }}cqw){% if section.settings.card_zoom_enable %} scale({{ section.settings.card_zoom_before_scale | divided_by: 100.0 }}){% endif %};
    {% if section.settings.card_zoom_enable %}
      transition: transform {{ section.settings.zoom_duration | divided_by: 1000.0 }}s cubic-bezier(0.16, 1, 0.3, 1);
      will-change: transform;
    {% endif %}
    {% if section.settings.show_card %}
      background: {{ section.settings.card_color | color_modify: 'alpha', card_alpha }};
      border: 1px solid rgba(255, 255, 255, 0.55);
      box-shadow:
        0 12px 34px -14px rgba(80, 50, 40, 0.4),
        inset 0 1px 0 rgba(255, 255, 255, 0.65);
      backdrop-filter: blur(6px) saturate(115%);
      -webkit-backdrop-filter: blur(6px) saturate(115%);
    {% endif %}
  }

  {% if section.settings.card_zoom_enable %}
    .waitlist-{{ section.id }}__card.waitlist-in-view {
      transform: translate({{ card_offset_x_mobile_cqw }}cqw, {{ card_offset_y_mobile_cqw }}cqw) scale({{ section.settings.card_zoom_after_scale | divided_by: 100.0 }});
    }
  {% endif %}

  @media screen and (min-width: 750px) {
    .waitlist-{{ section.id }}__card {
      transform: translate({{ card_offset_x_cqw }}cqw, {{ card_offset_y_cqw }}cqw){% if section.settings.card_zoom_enable %} scale({{ section.settings.card_zoom_before_scale | divided_by: 100.0 }}){% endif %};
    }

    {% if section.settings.card_zoom_enable %}
      .waitlist-{{ section.id }}__card.waitlist-in-view {
        transform: translate({{ card_offset_x_cqw }}cqw, {{ card_offset_y_cqw }}cqw) scale({{ section.settings.card_zoom_after_scale | divided_by: 100.0 }});
      }
    {% endif %}
  }

  .waitlist-{{ section.id }}__form-wrapper {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 21rem;
  }

  .waitlist-{{ section.id }}__form-wrapper .waitlist-signup-form,
  .waitlist-{{ section.id }}__fields {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    width: 100%;
    gap: clamp(0.7rem, 2.258cqw, 1.4rem);
  }

  /* Each field is a rose-water pill holding just the input + placeholder. */
  .waitlist-{{ section.id }}__field {
    box-sizing: border-box;
    display: flex;
    align-items: center;
    width: 100%;
    height: clamp({{ field_height_floor }}px, {{ field_height_cqw }}cqw, {{ section.settings.field_height }}px);
    border-radius: clamp({{ field_radius_floor }}px, {{ field_radius_cqw }}cqw, {{ section.settings.field_radius }}px);
    border: 1.5px solid {{ section.settings.window_frame_color | color_modify: 'alpha', 0.6 }};
    background: {{ section.settings.field_color }};
    box-shadow:
      0 6px 16px rgba(125, 74, 82, 0.16),
      inset 0 1px 0 rgba(255, 255, 255, 0.7);
    transition: border-color 0.18s ease, box-shadow 0.18s ease;
  }

  .waitlist-{{ section.id }}__field:focus-within {
    border-color: {{ section.settings.window_frame_color }};
    box-shadow:
      0 8px 20px rgba(125, 74, 82, 0.24),
      inset 0 1px 0 rgba(255, 255, 255, 0.75);
  }

  .waitlist-{{ section.id }}__form-wrapper .field__input {
    flex: 1;
    min-width: 0;
    width: 100%;
    height: 100%;
    border: none;
    background: transparent;
    padding: 0 1.4rem;
    margin: 0;
    box-shadow: none;
    font-size: clamp({{ input_size_floor | divided_by: 10.0 }}rem, {{ input_size_cqw }}cqw, {{ section.settings.input_size | divided_by: 10.0 }}rem);
    text-align: left;
    color: {{ section.settings.input_color }};
    {% if input_font %}
      font-family: {{ input_font.family }}, {{ input_font.fallback_families }};
      font-weight: {{ input_font.weight }};
      font-style: {{ input_font.style }};
    {% endif %}
  }

  .waitlist-{{ section.id }}__form-wrapper .field__input:focus {
    outline: none;
    box-shadow: none;
  }

  .waitlist-{{ section.id }}__form-wrapper .field__input::placeholder {
    opacity: 1 !important;
    color: {{ section.settings.input_color | color_modify: 'alpha', 0.7 }} !important;
    text-align: left;
  }

  /* Standalone, centered Join button. */
  .waitlist-{{ section.id }}__form-button {
    box-sizing: border-box;
    align-self: center;
    width: auto;
    min-width: 0;
    min-height: 0;
    height: auto;
    margin: 0.25rem 0 0;
    padding: clamp({{ button_padding_v_floor }}px, {{ button_padding_v_cqw }}cqw, {{ section.settings.button_padding_v }}px) clamp({{ button_padding_h_floor }}px, {{ button_padding_h_cqw }}cqw, {{ section.settings.button_padding_h }}px);
    border: none;
    border-radius: 999px;
    background: {{ section.settings.window_frame_color }};
    white-space: nowrap;
    line-height: 1;
    cursor: pointer;
    box-shadow: 0 8px 18px rgba(125, 74, 82, 0.32);
    transition: transform 0.15s ease, box-shadow 0.15s ease, filter 0.15s ease;
  }

  .waitlist-{{ section.id }}__form-button::before,
  .waitlist-{{ section.id }}__form-button::after {
    content: none;
  }

  .waitlist-{{ section.id }}__form-button:hover {
    transform: translateY(-1px);
    filter: brightness(1.05);
    box-shadow: 0 11px 24px rgba(125, 74, 82, 0.4);
  }

  .waitlist-{{ section.id }}__form-button:active {
    transform: translateY(0);
    box-shadow: 0 6px 14px rgba(125, 74, 82, 0.32);
  }

  .waitlist-{{ section.id }}__form-wrapper .field__label {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .waitlist-{{ section.id }}__form-error {
    margin-top: 0.5rem;
    text-align: center;
    color: {{ section.settings.window_frame_color }};
  }

  .waitlist-{{ section.id }}__form-error:not([hidden]) {
    display: block;
  }

  .waitlist-{{ section.id }}__form-success {
    box-sizing: border-box;
    gap: 0.5rem;
    width: 100%;
    margin: 0;
    padding: 0.8rem 1.4rem;
    border-radius: 999px;
    border: 1.5px solid {{ section.settings.window_frame_color }};
    background: rgba(255, 255, 255, 0.75);
    color: {{ section.settings.window_frame_color }};
    font-weight: 700;
  }

  .waitlist-{{ section.id }}__form-success:not([hidden]) {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .waitlist-{{ section.id }}__form-success svg {
    width: 1.2rem;
    height: 1.2rem;
    flex-shrink: 0;
  }

  .waitlist-{{ section.id }}__klaviyo-hidden {
    display: none;
  }
{%- endstyle -%}

<div class="waitlist-{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  {%- if section.settings.background_image != blank -%}
    <div class="waitlist-{{ section.id }}__background">
      {{
        section.settings.background_image
        | image_url: width: 3000
        | image_tag:
          loading: 'lazy',
          widths: '750, 1100, 1500, 2000, 3000',
          sizes: '100vw'
      }}
    </div>
    <div class="waitlist-{{ section.id }}__overlay"></div>
  {%- endif -%}

  <div class="waitlist-{{ section.id }}__content">
    {%- if section.settings.logo != blank -%}
      {%- liquid
        assign logo_class = 'waitlist-' | append: section.id | append: '__logo'
      -%}
      <div class="waitlist-{{ section.id }}__logo-wrapper">
        {{
          section.settings.logo
          | image_url: width: 2000
          | image_tag: class: logo_class, widths: '150, 300, 600, 1000, 1500, 2000'
        }}
      </div>
    {%- endif -%}

    {%- if section.settings.klaviyo_form_class != blank -%}
      <div class="waitlist-{{ section.id }}__window{% if settings.animations_reveal_on_scroll and section.settings.zoom_enable != true %} scroll-trigger animate--slide-in{% endif %}">
        {%- if section.settings.window_image != blank -%}
          <div class="waitlist-{{ section.id }}__window-image-frame">
            {{
              section.settings.window_image
              | image_url: width: 1500
              | image_tag: loading: 'lazy', widths: '375, 550, 750, 1100, 1500'
            }}
            <div class="waitlist-{{ section.id }}__window-image-slot">
              <div class="waitlist-{{ section.id }}__card">
                {%- if section.settings.heading != blank -%}
                  <h1 class="waitlist-{{ section.id }}__heading inline-richtext">
                    {{ section.settings.heading }}
                  </h1>
                {%- endif -%}

                {%- render 'waitlist-signup-form', section: section -%}
              </div>
            </div>
          </div>
        {%- else -%}
          <div class="waitlist-{{ section.id }}__window-arch" aria-hidden="true">
            <span class="waitlist-{{ section.id }}__window-mullion waitlist-{{ section.id }}__window-mullion--left"></span>
            <span class="waitlist-{{ section.id }}__window-mullion waitlist-{{ section.id }}__window-mullion--center"></span>
            <span class="waitlist-{{ section.id }}__window-mullion waitlist-{{ section.id }}__window-mullion--right"></span>
          </div>
          <div class="waitlist-{{ section.id }}__window-body">
            <div class="waitlist-{{ section.id }}__window-transom" aria-hidden="true"></div>

            <div class="waitlist-{{ section.id }}__card">
              {%- if section.settings.heading != blank -%}
                <h1 class="waitlist-{{ section.id }}__heading inline-richtext">
                  {{ section.settings.heading }}
                </h1>
              {%- endif -%}

              {%- render 'waitlist-signup-form', section: section -%}
            </div>
          </div>
          <div class="waitlist-{{ section.id }}__window-sill" aria-hidden="true"></div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <div class="waitlist-{{ section.id }}__subheading rte">
        {{ section.settings.subheading }}
      </div>
    {%- endif -%}

    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when '@app' -%}
          {% render block %}
      {%- endcase -%}
    {%- endfor -%}
  </div>
</div>

<script src="{{ 'waitlist-signup-form.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign any_zoom_enabled = false
  if section.settings.zoom_enable or section.settings.logo_zoom_enable or section.settings.subheading_zoom_enable or section.settings.background_zoom_enable or section.settings.card_zoom_enable
    assign any_zoom_enabled = true
  endif
-%}
{%- if any_zoom_enabled -%}
  <script>
    (function () {
      var selectors = [];
      {% if section.settings.zoom_enable %}selectors.push('.waitlist-{{ section.id }}__window');{% endif %}
      {% if section.settings.logo_zoom_enable %}selectors.push('.waitlist-{{ section.id }}__logo-wrapper');{% endif %}
      {% if section.settings.subheading_zoom_enable %}selectors.push('.waitlist-{{ section.id }}__subheading');{% endif %}
      {% if section.settings.background_zoom_enable %}selectors.push('.waitlist-{{ section.id }}');{% endif %}
      {% if section.settings.card_zoom_enable %}selectors.push('.waitlist-{{ section.id }}__card');{% endif %}

      var hasIO = 'IntersectionObserver' in window;

      selectors.forEach(function (selector) {
        var target = document.querySelector(selector);
        if (!target) return;

        function revealIn() {
          target.classList.add('waitlist-in-view');
        }

        if (!hasIO) {
          revealIn();
          return;
        }

        var observer = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              revealIn();
              observer.unobserve(target);
            }
          });
        }, { threshold: 0.2 });

        observer.observe(target);
      });
    })();
  </script>
{%- endif -%}

