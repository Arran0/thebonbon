{%- style -%}
  .waitlist-{{ section.id }} {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    min-height: {{ section.settings.min_height }}px;
  }

  @media screen and (min-width: 750px) {
    .waitlist-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .waitlist-{{ section.id }}__background {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .waitlist-{{ section.id }}__background img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .waitlist-{{ section.id }}__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  }

  .waitlist-{{ section.id }}__content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 68rem;
    margin: 0 auto;
    text-align: {{ section.settings.content_alignment }};
    display: flex;
    flex-direction: column;
    align-items: {% if section.settings.content_alignment == 'left' %}flex-start{% elsif section.settings.content_alignment == 'right' %}flex-end{% else %}center{% endif %};
    padding: 0 1.5rem;
  }

  .waitlist-{{ section.id }}__logo-wrapper {
    margin-bottom: 0.4rem;
  }

  .waitlist-{{ section.id }}__logo {
    width: {{ section.settings.logo_width }}px;
    max-width: 90%;
    height: auto;
  }

  /* Heading: bold, shiny dark pink with a slow foil sheen that
     glides across once, then rests, on a 10s loop. */
  .waitlist-{{ section.id }}__heading {
    margin: 0.3rem 0 0.7rem;
    font-size: 2.6rem;
    line-height: 1.1;
    font-weight: 700;
    letter-spacing: 0.01em;
    color: {{ section.settings.heading_color }};
    background-image: linear-gradient(
      105deg,
      {{ section.settings.heading_color }} 0%,
      {{ section.settings.heading_color }} 38%,
      {{ section.settings.heading_color | color_lighten: 32 }} 47%,
      #fff4f9 50%,
      {{ section.settings.heading_color | color_lighten: 32 }} 53%,
      {{ section.settings.heading_color }} 62%,
      {{ section.settings.heading_color }} 100%
    );
    background-size: 220% 100%;
    background-repeat: no-repeat;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    filter: drop-shadow(0 2px 6px {{ section.settings.heading_color | color_modify: 'alpha', 0.32 }});
    animation: waitlist-{{ section.id }}-sheen 10s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }

  @keyframes waitlist-{{ section.id }}-sheen {
    0% {
      background-position: 160% 0;
    }
    28%, 100% {
      background-position: -60% 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .waitlist-{{ section.id }}__heading {
      animation: none;
      background-position: -60% 0;
    }
  }

  @media screen and (min-width: 750px) {
    .waitlist-{{ section.id }}__heading {
      font-size: 3rem;
    }
  }

  .waitlist-{{ section.id }}__subheading {
    margin: 1.25rem 0 0;
    padding: 0.6rem 1.4rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.65);
    color: {{ section.settings.window_frame_color }};
    font-weight: 700;
    white-space: nowrap;
    max-width: 100%;
    overflow-x: auto;
  }

  .waitlist-{{ section.id }}__subheading p {
    margin: 0;
  }

  .waitlist-{{ section.id }}__window {
    position: relative;
    width: 100%;
    max-width: 62rem;
  }

  .waitlist-{{ section.id }}__window-image-frame {
    position: relative;
    width: 100%;
  }

  .waitlist-{{ section.id }}__window-image-frame img {
    display: block;
    width: 100%;
    height: auto;
  }

  .waitlist-{{ section.id }}__window-image-slot {
    position: absolute;
    top: {{ section.settings.window_image_slot_top }}%;
    left: {{ section.settings.window_image_slot_left }}%;
    width: {{ section.settings.window_image_slot_width }}%;
    height: {{ section.settings.window_image_slot_height }}%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.85rem;
    overflow: auto;
    padding: 0.5rem;
  }

  .waitlist-{{ section.id }}__window-arch {
    position: relative;
    width: 100%;
    aspect-ratio: 2 / 1;
    overflow: hidden;
    border: 7px solid {{ section.settings.window_frame_color }};
    border-bottom: none;
    border-radius: 50% 50% 0 0 / 100% 100% 0 0;
    background: {{ section.settings.window_glass_color | color_modify: 'alpha', section.settings.window_glass_opacity | divided_by: 100.0 }};
    backdrop-filter: blur(7px) saturate(115%);
    -webkit-backdrop-filter: blur(7px) saturate(115%);
    box-shadow: inset 0 0 22px rgba(255, 255, 255, 0.45);
  }

  .waitlist-{{ section.id }}__window-mullion {
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 2px;
    height: 100%;
    background: {{ section.settings.window_frame_color }};
    transform-origin: bottom center;
  }

  .waitlist-{{ section.id }}__window-mullion--left {
    transform: translateX(-50%) rotate(-30deg);
  }

  .waitlist-{{ section.id }}__window-mullion--center {
    transform: translateX(-50%);
  }

  .waitlist-{{ section.id }}__window-mullion--right {
    transform: translateX(-50%) rotate(30deg);
  }

  .waitlist-{{ section.id }}__window-body {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    gap: 1.25rem;
    border: 7px solid {{ section.settings.window_frame_color }};
    border-top: none;
    border-radius: 0 0 16px 16px;
    background: {{ section.settings.window_glass_color | color_modify: 'alpha', section.settings.window_glass_opacity | divided_by: 100.0 }};
    backdrop-filter: blur(7px) saturate(115%);
    -webkit-backdrop-filter: blur(7px) saturate(115%);
    box-shadow:
      inset 0 0 22px rgba(255, 255, 255, 0.35),
      0 20px 32px -14px rgba(80, 50, 40, 0.35);
    padding: 2rem 2rem 1.75rem;
    min-height: 16rem;
  }

  .waitlist-{{ section.id }}__window-transom {
    position: absolute;
    top: 0;
    left: -7px;
    right: -7px;
    height: 6px;
    background: {{ section.settings.window_frame_color }};
  }

  .waitlist-{{ section.id }}__window-sill {
    width: 112%;
    height: 8px;
    margin: 0 auto;
    transform: translateX(-5.4%);
    background: {{ section.settings.window_frame_color }};
    border-radius: 2px;
    box-shadow: 0 5px 10px rgba(80, 50, 40, 0.25);
  }

  .waitlist-{{ section.id }}__form-wrapper {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 21rem;
  }

  .waitlist-{{ section.id }}__form-wrapper .waitlist-signup-form,
  .waitlist-{{ section.id }}__fields {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    width: 100%;
    gap: 0.6rem;
  }

  /* Each field is a soft pink glass pill holding a white label chip + input. */
  .waitlist-{{ section.id }}__field {
    box-sizing: border-box;
    display: flex;
    align-items: center;
    gap: 0.55rem;
    width: 100%;
    height: 3.2rem;
    padding: 0 0.45rem 0 0.45rem;
    border-radius: 999px;
    border: 1.5px solid {{ section.settings.window_frame_color | color_modify: 'alpha', 0.7 }};
    background: {{ section.settings.window_glass_color | color_modify: 'alpha', 0.55 }};
    box-shadow:
      0 6px 16px rgba(125, 74, 82, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 0.65);
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
    transition: border-color 0.18s ease, box-shadow 0.18s ease;
  }

  .waitlist-{{ section.id }}__field:focus-within {
    border-color: {{ section.settings.window_frame_color }};
    box-shadow:
      0 8px 20px rgba(125, 74, 82, 0.26),
      inset 0 1px 0 rgba(255, 255, 255, 0.7);
  }

  /* White translucent pill label ("Name" / "Email") with pink text. */
  .waitlist-{{ section.id }}__field-badge {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.9rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.82);
    color: {{ section.settings.window_frame_color }};
    font-weight: 700;
    font-size: 1.3rem;
    letter-spacing: 0.01em;
    white-space: nowrap;
  }

  .waitlist-{{ section.id }}__form-wrapper .field__input {
    flex: 1;
    min-width: 0;
    width: 100%;
    height: 100%;
    border: none;
    background: transparent;
    padding: 0 0.6rem 0 0.2rem;
    margin: 0;
    box-shadow: none;
    font-size: 1.4rem;
    color: {{ section.settings.window_frame_color }};
  }

  .waitlist-{{ section.id }}__form-wrapper .field__input:focus {
    outline: none;
    box-shadow: none;
  }

  .waitlist-{{ section.id }}__form-wrapper .field__input::placeholder {
    color: {{ section.settings.window_frame_color | color_modify: 'alpha', 0.5 }};
  }

  /* Standalone, centered Join button. */
  .waitlist-{{ section.id }}__form-button {
    box-sizing: border-box;
    align-self: center;
    width: auto;
    min-width: 0;
    min-height: 0;
    height: auto;
    margin: 0.35rem 0 0;
    padding: 0.75rem 2.6rem;
    border: none;
    border-radius: 999px;
    background: {{ section.settings.window_frame_color }};
    color: {{ section.settings.window_glass_color }};
    font-weight: 700;
    font-size: 1.5rem;
    line-height: 1;
    letter-spacing: 0.03em;
    cursor: pointer;
    box-shadow: 0 8px 18px rgba(125, 74, 82, 0.32);
    transition: transform 0.15s ease, box-shadow 0.15s ease, filter 0.15s ease;
  }

  .waitlist-{{ section.id }}__form-button::before,
  .waitlist-{{ section.id }}__form-button::after {
    content: none;
  }

  .waitlist-{{ section.id }}__form-button:hover {
    transform: translateY(-1px);
    filter: brightness(1.05);
    box-shadow: 0 11px 24px rgba(125, 74, 82, 0.4);
  }

  .waitlist-{{ section.id }}__form-button:active {
    transform: translateY(0);
    box-shadow: 0 6px 14px rgba(125, 74, 82, 0.32);
  }

  .waitlist-{{ section.id }}__form-wrapper .field__label {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .waitlist-{{ section.id }}__form-error {
    margin-top: 0.5rem;
    text-align: center;
    color: {{ section.settings.window_frame_color }};
  }

  .waitlist-{{ section.id }}__form-error:not([hidden]) {
    display: block;
  }

  .waitlist-{{ section.id }}__form-success {
    box-sizing: border-box;
    gap: 0.5rem;
    width: 100%;
    margin: 0;
    padding: 0.8rem 1.4rem;
    border-radius: 999px;
    border: 1.5px solid {{ section.settings.window_frame_color }};
    background: rgba(255, 255, 255, 0.75);
    color: {{ section.settings.window_frame_color }};
    font-weight: 700;
  }

  .waitlist-{{ section.id }}__form-success:not([hidden]) {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .waitlist-{{ section.id }}__form-success svg {
    width: 1.2rem;
    height: 1.2rem;
    flex-shrink: 0;
  }

  .waitlist-{{ section.id }}__klaviyo-hidden {
    display: none;
  }
{%- endstyle -%}

<div class="waitlist-{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  {%- if section.settings.background_image != blank -%}
    <div class="waitlist-{{ section.id }}__background">
      {{
        section.settings.background_image
        | image_url: width: 3000
        | image_tag:
          loading: 'lazy',
          widths: '750, 1100, 1500, 2000, 3000',
          sizes: '100vw'
      }}
    </div>
    <div class="waitlist-{{ section.id }}__overlay"></div>
  {%- endif -%}

  <div class="waitlist-{{ section.id }}__content page-width page-width--narrow">
    {%- if section.settings.logo != blank -%}
      {%- liquid
        assign logo_class = 'waitlist-' | append: section.id | append: '__logo'
      -%}
      <div class="waitlist-{{ section.id }}__logo-wrapper{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
        {{
          section.settings.logo
          | image_url: width: 2000
          | image_tag: class: logo_class, widths: '150, 300, 600, 1000, 1500, 2000'
        }}
      </div>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="waitlist-{{ section.id }}__heading inline-richtext">
        {{ section.settings.heading }}
      </h1>
    {%- endif -%}

    {%- if section.settings.klaviyo_form_class != blank -%}
      <div class="waitlist-{{ section.id }}__window{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {%- if section.settings.window_image != blank -%}
          <div class="waitlist-{{ section.id }}__window-image-frame">
            {{
              section.settings.window_image
              | image_url: width: 1500
              | image_tag: loading: 'lazy', widths: '375, 550, 750, 1100, 1500'
            }}
            <div class="waitlist-{{ section.id }}__window-image-slot">
              {%- render 'waitlist-signup-form', section: section -%}
            </div>
          </div>
        {%- else -%}
          <div class="waitlist-{{ section.id }}__window-arch" aria-hidden="true">
            <span class="waitlist-{{ section.id }}__window-mullion waitlist-{{ section.id }}__window-mullion--left"></span>
            <span class="waitlist-{{ section.id }}__window-mullion waitlist-{{ section.id }}__window-mullion--center"></span>
            <span class="waitlist-{{ section.id }}__window-mullion waitlist-{{ section.id }}__window-mullion--right"></span>
          </div>
          <div class="waitlist-{{ section.id }}__window-body">
            <div class="waitlist-{{ section.id }}__window-transom" aria-hidden="true"></div>

            {%- render 'waitlist-signup-form', section: section -%}
          </div>
          <div class="waitlist-{{ section.id }}__window-sill" aria-hidden="true"></div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <div class="waitlist-{{ section.id }}__subheading rte{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {{ section.settings.subheading }}
      </div>
    {%- endif -%}

    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when '@app' -%}
          {% render block %}
      {%- endcase -%}
    {%- endfor -%}
  </div>
</div>

<script src="{{ 'waitlist-signup-form.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Waitlist",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading (shown inside the window)",
      "default": "Save your spot!"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "info": "A bold, shiny dark pink. The heading types itself out and re-loops every 10 seconds.",
      "default": "#C2185B"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading (shown below the window)",
      "default": "<p>Launch offers, goodies and exclusive deals for you 🎀</p>"
    },
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image",
      "info": "Choose your logo file here -- it renders above the window."
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 1000,
      "step": 10,
      "unit": "px",
      "label": "Logo width",
      "default": 150
    },
    {
      "type": "header",
      "content": "Signup form"
    },
    {
      "type": "paragraph",
      "content": "The visible First name + Email fields and Join button are built and styled by this theme and submit straight to Klaviyo's API using the key and list below."
    },
    {
      "type": "text",
      "id": "klaviyo_public_api_key",
      "label": "Klaviyo Public API Key",
      "info": "Klaviyo > Settings (gear icon) > API Keys > Public API Key.",
      "default": "Vx3Bbq"
    },
    {
      "type": "text",
      "id": "klaviyo_list_id",
      "label": "Klaviyo List ID",
      "info": "The ID in your list's URL, e.g. klaviyo.com/list/XXXXXX.",
      "default": "U9Lfmn"
    },
    {
      "type": "text",
      "id": "klaviyo_form_class",
      "label": "Old Klaviyo form embed class (kept hidden on the page)",
      "info": "No longer used for submission -- kept hidden with display:none in case you want it back. Clear it to remove entirely.",
      "default": "klaviyo-form-SYVDuv"
    },
    {
      "type": "header",
      "content": "Arched window"
    },
    {
      "type": "paragraph",
      "content": "The signup form is framed by an arched window. Upload your own window graphic below to replace the built-in CSS window, or leave it blank to keep the tinted-glass version."
    },
    {
      "type": "image_picker",
      "id": "window_image",
      "label": "Window image",
      "info": "A PNG with a transparent center panel works best -- the form renders inside that opening."
    },
    {
      "type": "range",
      "id": "window_image_slot_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Form position: top",
      "info": "Nudge these 4 values until the form lines up with the clear opening in your window image.",
      "default": 37
    },
    {
      "type": "range",
      "id": "window_image_slot_left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Form position: left",
      "default": 24
    },
    {
      "type": "range",
      "id": "window_image_slot_width",
      "min": 10,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Form position: width",
      "default": 52
    },
    {
      "type": "range",
      "id": "window_image_slot_height",
      "min": 10,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Form position: height",
      "default": 49
    },
    {
      "type": "color",
      "id": "window_frame_color",
      "label": "Window frame color (used when no window image is set)",
      "default": "#7D4A52"
    },
    {
      "type": "color",
      "id": "window_glass_color",
      "label": "Glass color (used when no window image is set)",
      "default": "#F7CAD0"
    },
    {
      "type": "range",
      "id": "window_glass_opacity",
      "min": 10,
      "max": 70,
      "step": 5,
      "unit": "%",
      "label": "Glass opacity (used when no window image is set)",
      "default": 30
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#7D4A52"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 40
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 200,
      "max": 800,
      "step": 20,
      "unit": "px",
      "label": "Minimum section height",
      "default": 400
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center",
      "label": "Content alignment"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-6"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "Waitlist"
    }
  ]
}
{% endschema %}
