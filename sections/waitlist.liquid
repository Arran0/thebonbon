{%- liquid
  assign heading_font = section.settings.accent_font
  assign subheading_font = section.settings.subheading_font
  assign button_font = section.settings.button_font
  assign input_font = section.settings.input_font
  assign card_alpha = section.settings.card_opacity | divided_by: 100.0
-%}
{%- style -%}
  {% if heading_font %}{{ heading_font | font_face: font_display: 'swap' }}{% endif %}
  {% if subheading_font %}{{ subheading_font | font_face: font_display: 'swap' }}{% endif %}
  {% if button_font %}{{ button_font | font_face: font_display: 'swap' }}{% endif %}
  {% if input_font %}{{ input_font | font_face: font_display: 'swap' }}{% endif %}

  .waitlist-{{ section.id }} {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    min-height: {{ section.settings.min_height }}px;
  }

  @media screen and (min-width: 750px) {
    .waitlist-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .waitlist-{{ section.id }}__background {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .waitlist-{{ section.id }}__background img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .waitlist-{{ section.id }}__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  }

  .waitlist-{{ section.id }}__content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 68rem;
    margin: 0 auto;
    text-align: {{ section.settings.content_alignment }};
    display: flex;
    flex-direction: column;
    align-items: {% if section.settings.content_alignment == 'left' %}flex-start{% elsif section.settings.content_alignment == 'right' %}flex-end{% else %}center{% endif %};
    padding: 0 1.5rem;
  }

  .waitlist-{{ section.id }}__logo-wrapper {
    margin-bottom: 0.4rem;
  }

  .waitlist-{{ section.id }}__logo {
    width: {{ section.settings.logo_width }}px;
    max-width: 90%;
    height: auto;
  }

  /* Every piece of text on the page has its own font / size / color,
     all editable from the theme editor's Typography section. */
  .waitlist-{{ section.id }}__heading {
    margin: 0;
    line-height: 1.2;
    letter-spacing: 0.06em;
    font-size: {{ section.settings.heading_size | divided_by: 10.0 }}rem;
    color: {{ section.settings.heading_color }};
    {% if heading_font %}
      font-family: {{ heading_font.family }}, {{ heading_font.fallback_families }};
      font-weight: {{ heading_font.weight }};
      font-style: {{ heading_font.style }};
    {% else %}
      font-weight: 700;
    {% endif %}
  }

  .waitlist-{{ section.id }}__form-button {
    letter-spacing: 0.06em;
    font-size: {{ section.settings.button_size | divided_by: 10.0 }}rem;
    color: {{ section.settings.button_color }};
    {% if button_font %}
      font-family: {{ button_font.family }}, {{ button_font.fallback_families }};
      font-weight: {{ button_font.weight }};
      font-style: {{ button_font.style }};
    {% else %}
      font-weight: 700;
    {% endif %}
  }

  .waitlist-{{ section.id }}__subheading {
    margin: 1.25rem 0 0;
    padding: 0.6rem 1.4rem;
    border-radius: 999px;
    background: #ffffff;
    white-space: nowrap;
    max-width: 100%;
    overflow-x: auto;
    letter-spacing: 0.06em;
    font-size: {{ section.settings.subheading_size | divided_by: 10.0 }}rem;
    color: {{ section.settings.subheading_color }};
    {% if subheading_font %}
      font-family: {{ subheading_font.family }}, {{ subheading_font.fallback_families }};
      font-weight: {{ subheading_font.weight }};
      font-style: {{ subheading_font.style }};
    {% else %}
      font-weight: 700;
    {% endif %}
  }

  /* Normalize whatever tag the subheading richtext uses (p, h5, ...)
     so it always renders in the shared accent style, not a heading. */
  .waitlist-{{ section.id }}__subheading > * {
    margin: 0;
    font-size: inherit;
    font-weight: inherit;
    font-family: inherit;
    letter-spacing: inherit;
    color: inherit;
    line-height: 1.3;
  }

  .waitlist-{{ section.id }}__window {
    position: relative;
    width: 100%;
    max-width: 62rem;
  }

  .waitlist-{{ section.id }}__window-image-frame {
    position: relative;
    width: 100%;
  }

  .waitlist-{{ section.id }}__window-image-frame img {
    display: block;
    width: 100%;
    height: auto;
  }

  .waitlist-{{ section.id }}__window-image-slot {
    position: absolute;
    top: {{ section.settings.window_image_slot_top }}%;
    left: {{ section.settings.window_image_slot_left }}%;
    width: {{ section.settings.window_image_slot_width }}%;
    height: {{ section.settings.window_image_slot_height }}%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.3rem;
    overflow: visible;
    padding: 0.5rem;
  }

  .waitlist-{{ section.id }}__window-arch {
    position: relative;
    width: 100%;
    aspect-ratio: 2 / 1;
    overflow: hidden;
    border: 7px solid {{ section.settings.window_frame_color }};
    border-bottom: none;
    border-radius: 50% 50% 0 0 / 100% 100% 0 0;
    background: {{ section.settings.window_glass_color | color_modify: 'alpha', section.settings.window_glass_opacity | divided_by: 100.0 }};
    backdrop-filter: blur(7px) saturate(115%);
    -webkit-backdrop-filter: blur(7px) saturate(115%);
    box-shadow: inset 0 0 22px rgba(255, 255, 255, 0.45);
  }

  .waitlist-{{ section.id }}__window-mullion {
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 2px;
    height: 100%;
    background: {{ section.settings.window_frame_color }};
    transform-origin: bottom center;
  }

  .waitlist-{{ section.id }}__window-mullion--left {
    transform: translateX(-50%) rotate(-30deg);
  }

  .waitlist-{{ section.id }}__window-mullion--center {
    transform: translateX(-50%);
  }

  .waitlist-{{ section.id }}__window-mullion--right {
    transform: translateX(-50%) rotate(30deg);
  }

  .waitlist-{{ section.id }}__window-body {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    border: 7px solid {{ section.settings.window_frame_color }};
    border-top: none;
    border-radius: 0 0 16px 16px;
    background: {{ section.settings.window_glass_color | color_modify: 'alpha', section.settings.window_glass_opacity | divided_by: 100.0 }};
    backdrop-filter: blur(7px) saturate(115%);
    -webkit-backdrop-filter: blur(7px) saturate(115%);
    box-shadow:
      inset 0 0 22px rgba(255, 255, 255, 0.35),
      0 20px 32px -14px rgba(80, 50, 40, 0.35);
    padding: 2rem 2rem 1.75rem;
    min-height: 16rem;
  }

  .waitlist-{{ section.id }}__window-transom {
    position: absolute;
    top: 0;
    left: -7px;
    right: -7px;
    height: 6px;
    background: {{ section.settings.window_frame_color }};
  }

  .waitlist-{{ section.id }}__window-sill {
    width: 112%;
    height: 8px;
    margin: 0 auto;
    transform: translateX(-5.4%);
    background: {{ section.settings.window_frame_color }};
    border-radius: 2px;
    box-shadow: 0 5px 10px rgba(80, 50, 40, 0.25);
  }

  /* White translucent card that groups the heading + form together.
     Its corner position and size are driven by the theme editor. */
  .waitlist-{{ section.id }}__card {
    position: relative;
    z-index: 1;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.3rem;
    width: 100%;
    max-width: {{ section.settings.card_width }}%;
    min-height: {{ section.settings.card_min_height }}px;
    padding: {{ section.settings.card_padding }}px;
    border-radius: {{ section.settings.card_radius }}px;
    transform: translate({{ section.settings.card_offset_x }}px, {{ section.settings.card_offset_y }}px);
    {% if section.settings.show_card %}
      background: {{ section.settings.card_color | color_modify: 'alpha', card_alpha }};
      border: 1px solid rgba(255, 255, 255, 0.55);
      box-shadow:
        0 12px 34px -14px rgba(80, 50, 40, 0.4),
        inset 0 1px 0 rgba(255, 255, 255, 0.65);
      backdrop-filter: blur(6px) saturate(115%);
      -webkit-backdrop-filter: blur(6px) saturate(115%);
    {% endif %}
  }

  .waitlist-{{ section.id }}__form-wrapper {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 21rem;
  }

  .waitlist-{{ section.id }}__form-wrapper .waitlist-signup-form,
  .waitlist-{{ section.id }}__fields {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    width: 100%;
    gap: 1.4rem;
  }

  /* Each field is a rose-water pill holding just the input + placeholder. */
  .waitlist-{{ section.id }}__field {
    box-sizing: border-box;
    display: flex;
    align-items: center;
    width: 100%;
    height: 3.2rem;
    border-radius: 999px;
    border: 1.5px solid {{ section.settings.window_frame_color | color_modify: 'alpha', 0.6 }};
    background: {{ section.settings.field_color }};
    box-shadow:
      0 6px 16px rgba(125, 74, 82, 0.16),
      inset 0 1px 0 rgba(255, 255, 255, 0.7);
    transition: border-color 0.18s ease, box-shadow 0.18s ease;
  }

  .waitlist-{{ section.id }}__field:focus-within {
    border-color: {{ section.settings.window_frame_color }};
    box-shadow:
      0 8px 20px rgba(125, 74, 82, 0.24),
      inset 0 1px 0 rgba(255, 255, 255, 0.75);
  }

  .waitlist-{{ section.id }}__form-wrapper .field__input {
    flex: 1;
    min-width: 0;
    width: 100%;
    height: 100%;
    border: none;
    background: transparent;
    padding: 0 1.4rem;
    margin: 0;
    box-shadow: none;
    font-size: {{ section.settings.input_size | divided_by: 10.0 }}rem;
    text-align: left;
    color: {{ section.settings.input_color }};
    {% if input_font %}
      font-family: {{ input_font.family }}, {{ input_font.fallback_families }};
      font-weight: {{ input_font.weight }};
      font-style: {{ input_font.style }};
    {% endif %}
  }

  .waitlist-{{ section.id }}__form-wrapper .field__input:focus {
    outline: none;
    box-shadow: none;
  }

  .waitlist-{{ section.id }}__form-wrapper .field__input::placeholder {
    opacity: 1 !important;
    color: {{ section.settings.input_color | color_modify: 'alpha', 0.7 }} !important;
    text-align: left;
  }

  /* Standalone, centered Join button. */
  .waitlist-{{ section.id }}__form-button {
    box-sizing: border-box;
    align-self: center;
    width: auto;
    min-width: 0;
    min-height: 0;
    height: auto;
    margin: 0.25rem 0 0;
    padding: 0.85rem 2.8rem;
    border: none;
    border-radius: 999px;
    background: {{ section.settings.window_frame_color }};
    line-height: 1;
    cursor: pointer;
    box-shadow: 0 8px 18px rgba(125, 74, 82, 0.32);
    transition: transform 0.15s ease, box-shadow 0.15s ease, filter 0.15s ease;
  }

  .waitlist-{{ section.id }}__form-button::before,
  .waitlist-{{ section.id }}__form-button::after {
    content: none;
  }

  .waitlist-{{ section.id }}__form-button:hover {
    transform: translateY(-1px);
    filter: brightness(1.05);
    box-shadow: 0 11px 24px rgba(125, 74, 82, 0.4);
  }

  .waitlist-{{ section.id }}__form-button:active {
    transform: translateY(0);
    box-shadow: 0 6px 14px rgba(125, 74, 82, 0.32);
  }

  .waitlist-{{ section.id }}__form-wrapper .field__label {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .waitlist-{{ section.id }}__form-error {
    margin-top: 0.5rem;
    text-align: center;
    color: {{ section.settings.window_frame_color }};
  }

  .waitlist-{{ section.id }}__form-error:not([hidden]) {
    display: block;
  }

  .waitlist-{{ section.id }}__form-success {
    box-sizing: border-box;
    gap: 0.5rem;
    width: 100%;
    margin: 0;
    padding: 0.8rem 1.4rem;
    border-radius: 999px;
    border: 1.5px solid {{ section.settings.window_frame_color }};
    background: rgba(255, 255, 255, 0.75);
    color: {{ section.settings.window_frame_color }};
    font-weight: 700;
  }

  .waitlist-{{ section.id }}__form-success:not([hidden]) {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .waitlist-{{ section.id }}__form-success svg {
    width: 1.2rem;
    height: 1.2rem;
    flex-shrink: 0;
  }

  .waitlist-{{ section.id }}__klaviyo-hidden {
    display: none;
  }
{%- endstyle -%}

<div class="waitlist-{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  {%- if section.settings.background_image != blank -%}
    <div class="waitlist-{{ section.id }}__background">
      {{
        section.settings.background_image
        | image_url: width: 3000
        | image_tag:
          loading: 'lazy',
          widths: '750, 1100, 1500, 2000, 3000',
          sizes: '100vw'
      }}
    </div>
    <div class="waitlist-{{ section.id }}__overlay"></div>
  {%- endif -%}

  <div class="waitlist-{{ section.id }}__content page-width page-width--narrow">
    {%- if section.settings.logo != blank -%}
      {%- liquid
        assign logo_class = 'waitlist-' | append: section.id | append: '__logo'
      -%}
      <div class="waitlist-{{ section.id }}__logo-wrapper{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
        {{
          section.settings.logo
          | image_url: width: 2000
          | image_tag: class: logo_class, widths: '150, 300, 600, 1000, 1500, 2000'
        }}
      </div>
    {%- endif -%}

    {%- if section.settings.klaviyo_form_class != blank -%}
      <div class="waitlist-{{ section.id }}__window{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {%- if section.settings.window_image != blank -%}
          <div class="waitlist-{{ section.id }}__window-image-frame">
            {{
              section.settings.window_image
              | image_url: width: 1500
              | image_tag: loading: 'lazy', widths: '375, 550, 750, 1100, 1500'
            }}
            <div class="waitlist-{{ section.id }}__window-image-slot">
              <div class="waitlist-{{ section.id }}__card">
                {%- if section.settings.heading != blank -%}
                  <h1 class="waitlist-{{ section.id }}__heading inline-richtext">
                    {{ section.settings.heading }}
                  </h1>
                {%- endif -%}

                {%- render 'waitlist-signup-form', section: section -%}
              </div>
            </div>
          </div>
        {%- else -%}
          <div class="waitlist-{{ section.id }}__window-arch" aria-hidden="true">
            <span class="waitlist-{{ section.id }}__window-mullion waitlist-{{ section.id }}__window-mullion--left"></span>
            <span class="waitlist-{{ section.id }}__window-mullion waitlist-{{ section.id }}__window-mullion--center"></span>
            <span class="waitlist-{{ section.id }}__window-mullion waitlist-{{ section.id }}__window-mullion--right"></span>
          </div>
          <div class="waitlist-{{ section.id }}__window-body">
            <div class="waitlist-{{ section.id }}__window-transom" aria-hidden="true"></div>

            <div class="waitlist-{{ section.id }}__card">
              {%- if section.settings.heading != blank -%}
                <h1 class="waitlist-{{ section.id }}__heading inline-richtext">
                  {{ section.settings.heading }}
                </h1>
              {%- endif -%}

              {%- render 'waitlist-signup-form', section: section -%}
            </div>
          </div>
          <div class="waitlist-{{ section.id }}__window-sill" aria-hidden="true"></div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <div class="waitlist-{{ section.id }}__subheading rte{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {{ section.settings.subheading }}
      </div>
    {%- endif -%}

    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when '@app' -%}
          {% render block %}
      {%- endcase -%}
    {%- endfor -%}
  </div>
</div>

<script src="{{ 'waitlist-signup-form.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Waitlist",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading (shown inside the window)",
      "default": "Save your spot!"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading (shown below the window)",
      "default": "<p>Launch offers, goodies and exclusive deals for you 🎀</p>"
    },
    {
      "type": "header",
      "content": "Typography",
      "info": "Every piece of text on the page -- heading, subheading, Join button label and the Name/Email inputs -- has its own font, size and color below."
    },
    {
      "type": "font_picker",
      "id": "accent_font",
      "label": "Heading font",
      "info": "Try \"Optima\" for a look close to the original design.",
      "default": "assistant_n4"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 10,
      "max": 80,
      "step": 1,
      "unit": "px",
      "label": "Heading size",
      "default": 16
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#FF97A3"
    },
    {
      "type": "font_picker",
      "id": "subheading_font",
      "label": "Subheading font",
      "default": "assistant_n4"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "min": 10,
      "max": 60,
      "step": 1,
      "unit": "px",
      "label": "Subheading size",
      "default": 16
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#FF97A3"
    },
    {
      "type": "font_picker",
      "id": "button_font",
      "label": "Join button font",
      "default": "assistant_n4"
    },
    {
      "type": "range",
      "id": "button_size",
      "min": 10,
      "max": 60,
      "step": 1,
      "unit": "px",
      "label": "Join button label size",
      "default": 16
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Join button label color",
      "default": "#FF97A3"
    },
    {
      "type": "font_picker",
      "id": "input_font",
      "label": "Input text font",
      "default": "assistant_n4"
    },
    {
      "type": "range",
      "id": "input_size",
      "min": 10,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Input text size",
      "default": 14
    },
    {
      "type": "color",
      "id": "input_color",
      "label": "Input & placeholder color",
      "default": "#7D4A52"
    },
    {
      "type": "header",
      "content": "Card",
      "info": "A translucent white square that groups the heading and the signup form together. Because the card, its text and the window are all part of this one section, they move as a single locked group -- the corner controls below keep the card aligned inside the window."
    },
    {
      "type": "checkbox",
      "id": "show_card",
      "label": "Show translucent card",
      "default": true
    },
    {
      "type": "color",
      "id": "card_color",
      "label": "Card color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "card_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Card opacity (translucency)",
      "default": 55
    },
    {
      "type": "range",
      "id": "card_width",
      "min": 40,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Card width (right corner)",
      "default": 100
    },
    {
      "type": "range",
      "id": "card_min_height",
      "min": 0,
      "max": 500,
      "step": 5,
      "unit": "px",
      "label": "Card minimum height (bottom corner)",
      "default": 0
    },
    {
      "type": "range",
      "id": "card_offset_x",
      "min": -200,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Card horizontal offset (left corner)",
      "default": 0
    },
    {
      "type": "range",
      "id": "card_offset_y",
      "min": -200,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Card vertical offset (top corner)",
      "default": 0
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "px",
      "label": "Card corner rounding",
      "default": 18
    },
    {
      "type": "range",
      "id": "card_padding",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Card inner padding",
      "default": 20
    },
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image",
      "info": "Choose your logo file here -- it renders above the window."
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 1000,
      "step": 10,
      "unit": "px",
      "label": "Logo width",
      "default": 150
    },
    {
      "type": "header",
      "content": "Signup form"
    },
    {
      "type": "paragraph",
      "content": "The visible Name + Email fields and Join button are built and styled by this theme and submit straight to Klaviyo's API using the key and list below."
    },
    {
      "type": "color",
      "id": "field_color",
      "label": "Input box color",
      "info": "Fill for the Name and Email boxes. Default is rose water.",
      "default": "#F7DEDE"
    },
    {
      "type": "text",
      "id": "klaviyo_public_api_key",
      "label": "Klaviyo Public API Key",
      "info": "Klaviyo > Settings (gear icon) > API Keys > Public API Key.",
